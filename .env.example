# ---------------------------------------------------------------------------
# contrib-compass environment variables
#
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is in .gitignore.
# ---------------------------------------------------------------------------

# ── Required ──────────────────────────────────────────────────────────────
# Your GitHub Personal Access Token.
# Needed for higher API rate limits (5 000 req/hr vs 60 req/hr unauthenticated).
# Create one at: https://github.com/settings/tokens
# Required scopes: public_repo (read-only is fine)
GITHUB_TOKEN=ghp_your_token_here

# ── Optional ──────────────────────────────────────────────────────────────
# Sentence-transformers model used for semantic re-ranking.
# Default: all-MiniLM-L6-v2  (~80 MB, good balance of speed and accuracy)
# Alternatives: paraphrase-MiniLM-L3-v2 (smaller, faster, lower accuracy)
MODEL_NAME=all-MiniLM-L6-v2

# Directory where sentence-transformers caches the downloaded model.
# Defaults to .cache/ inside the project root.
# Change this if you want to share a model cache across projects.
SENTENCE_TRANSFORMERS_HOME=.cache

# Maximum number of repos returned per analysis (default: 20)
MAX_REPOS=20

# Maximum number of issues returned per analysis (default: 50)
MAX_ISSUES=50

# Port the FastAPI server listens on (default: 8000)
PORT=8000

# Log level: debug | info | warning | error (default: info)
LOG_LEVEL=info
